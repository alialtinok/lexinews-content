# Hangi AI provider kullanılacak? "gemini" veya "claude"
# Varsayılan: gemini (ücretsiz)
AI_PROVIDER=gemini

# Gemini API Key (varsayılan provider)
# Ücretsiz: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Claude API Key (opsiyonel, AI_PROVIDER=claude yaparsan gerekli)
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
